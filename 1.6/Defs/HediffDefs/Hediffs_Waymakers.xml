<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="MoteBase">
    <defName>WM_Mote_CoordinateWorks</defName>
    <label>coordinate works</label>
    <thingClass>MoteAttached</thingClass>
    <altitudeLayer>LightingOverlay</altitudeLayer>
    <drawOffscreen>true</drawOffscreen>
    <mote>
      <solidTime>9999999</solidTime>
      <needsMaintenance>true</needsMaintenance>
    </mote>
    <graphicData>
      <graphicClass>Graphic_Mote</graphicClass>
      <texPath>Things/Mote/CombatCommandMask</texPath>
      <shaderType>MoteGlow</shaderType>
      <color>(1, 1, 1, 0.5)</color>
      <drawSize>39.6</drawSize>
    </graphicData>
  </ThingDef>

  <HediffDef ParentName="RoleStatBuff">
    <defName>WM_CoordinateWorks</defName>
    <label>coordinate works</label>
    <description>This person is coordinating construction and logistics, boosting efficiency for everyone nearby by 75%. When present in a caravan, road building speed is doubled.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>True</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath"/>
      <li Class="HediffCompProperties_GiveHediffsInRange">
        <range>19.8</range>
        <mote>WM_Mote_CoordinateWorks</mote>
        <hideMoteWhenNotDrafted>true</hideMoteWhenNotDrafted>
        <targetingParameters>
          <canTargetBuildings>false</canTargetBuildings>
          <canTargetAnimals>false</canTargetAnimals>
          <canTargetMechs>false</canTargetMechs>
          <onlyTargetColonists>true</onlyTargetColonists>
        </targetingParameters>
        <hediff>WM_CoordinateWorksBuff</hediff>
      </li>
    </comps>
    <isBad>false</isBad>
  </HediffDef>

  <HediffDef>
    <defName>WM_CoordinateWorksBuff</defName>
    <label>coordinate works</label>
    <description>This person's construction speed is boosted thanks to being near a surveyor using coordinate works.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.52, 1, 0.95)</defaultLabelColor>
    <debugLabelExtra>other</debugLabelExtra>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>false</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath"/>
      <li Class="HediffCompProperties_Link">
        <requireLinkOnOtherPawn>false</requireLinkOnOtherPawn>
        <maxDistance>19.8</maxDistance>
        <customMote>Mote_WorkCommandLinkLine</customMote>
      </li>
    </comps>
    <stages>
      <li>
        <statOffsets>
          <ConstructionSpeed>0.75</ConstructionSpeed>
        </statOffsets>
      </li>
    </stages>
    <isBad>false</isBad>
  </HediffDef>

  <HediffDef>
    <defName>WM_GroundbreakingBuff</defName>
    <label>groundbreaking inspiration</label>
    <description>Inspired by the groundbreaking ceremony, this person's construction speed is increased.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.52, 1, 0.95)</defaultLabelColor>
    <debugLabelExtra>other</debugLabelExtra>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>True</showRemainingTime>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath"/>
    </comps>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <statOffsets>
          <ConstructionSpeed>0.25</ConstructionSpeed>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.33</minSeverity>
        <statOffsets>
          <ConstructionSpeed>0.35</ConstructionSpeed>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.66</minSeverity>
        <statOffsets>
          <ConstructionSpeed>0.50</ConstructionSpeed>
        </statOffsets>
      </li>
    </stages>
    <isBad>false</isBad>
  </HediffDef>

</Defs>
