<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <PreceptDef ParentName="PreceptRoleSingleBase">
    <defName>WM_IdeoRole_Surveyor</defName>
    <label>surveyor</label>
    <description>A specialist dedicated to infrastructure and logistics. Surveyors coordinate road-building efforts, manage resources, and ensure settlements remain connected. Their presence accelerates construction and mining, and they can inspire nearby workers with the Coordinate Works ability.</description>
    <iconPath>UI/Roles/Surveyor</iconPath>
    <nameMaker>WM_NamerRoleSurveyor</nameMaker>
    <roleRequirements>
      <li Class="RoleRequirement_MinSkillAny">
        <skills>
          <Construction>6</Construction>
          <Intellectual>4</Intellectual>
        </skills>
      </li>
    </roleRequirements>
    <roleTags>
      <li>Surveyor</li>
    </roleTags>
    <requiredMemes>
      <li>WM_Waymakers</li>
    </requiredMemes>
    <roleEffects>
      <li Class="RoleEffect_PawnStatOffset">
        <statDef>ConstructionSpeed</statDef>
        <modifier>0.50</modifier>
      </li>
      <li Class="RoleEffect_PawnStatOffset">
        <statDef>MiningSpeed</statDef>
        <modifier>0.20</modifier>
      </li>
    </roleEffects>
    <grantedAbilities>
      <li>WM_CoordinateWorks</li>
    </grantedAbilities>
    <roleDisabledWorkTags>
      <li>Cooking</li>
      <li>PlantWork</li>
      <li>Animals</li>
      <li>Artistic</li>
    </roleDisabledWorkTags>
    <displayOrderInImpact>2</displayOrderInImpact>
  </PreceptDef>

</Defs>
